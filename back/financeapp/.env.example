# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=openfinance-dashboard
SERVER_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

# ─────────────────────────────────────────────────────────────────────────────
# MONGODB
# ─────────────────────────────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=financeapp

# ─────────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─────────────────────────────────────────────────────────────────────────────
# AKROPOLI OPEN FINANCE
# Substituiu a integração Pluggy. Obter credenciais no portal da Akropoli.
# ─────────────────────────────────────────────────────────────────────────────
AKROPOLI_BASE_URL=https://api.akropoli.com.br
AKROPOLI_CLIENT_ID=your-client-id-here
AKROPOLI_CLIENT_SECRET=your-client-secret-here
# Secret HMAC para validar assinatura dos webhooks recebidos da Akropoli.
# Deixar em branco desativa a verificação (apenas em dev local).
AKROPOLI_WEBHOOK_SECRET=
# TTL do token de acesso em segundos. Confirmar com o suporte da Akropoli.
AKROPOLI_TOKEN_TTL=3600

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# Origens permitidas pelo backend. Em dev: portas padrão React/Vite.
# Em produção: trocar pelo domínio real do frontend.
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTION
# Chave AES-256 para criptografia de campos sensíveis (CPF, email, linkId,
# tokenHash). Gerar com: openssl rand -base64 32
# NUNCA commitar o valor real no git. Trocar em produção.
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=GERE_COM_openssl_rand_-base64_32_E_SUBSTITUA_AQUI

# HASH_SECRET: chave HMAC-SHA256 para hashes determinísticos de busca.
# SEPARADA da ENCRYPTION_KEY — comprometer uma não compromete a outra.
# Gerar com: openssl rand -base64 32
HASH_SECRET=GERE_COM_openssl_rand_-base64_32_E_SUBSTITUA_AQUI